{
  "title": "GrafanAgent — Agent Ops",
  "uid": "grafanagent-overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["grafanagent", "ai", "agents"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
        "query": "label_values(service_name)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Cost & tokens",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Tokens (placeholder)",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Estimated $ cost (placeholder)",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Latency & success",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "p95 latency by service (placeholder)",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Success rate (placeholder)",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Traces",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "type": "traces",
      "title": "Recent agent traces (Tempo, placeholder)",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 10 }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Eval (golden set)",
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 }
    },
    {
      "id": 31,
      "type": "gauge",
      "title": "Pass rate (llm mode, last run)",
      "gridPos": { "x": 0, "y": 26, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "grafanagent_eval_pass_rate{set=\"golden_set\", mode=\"llm\"}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 0.7 },
              { "color": "green", "value": 0.85 }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Mean judge score by dimension",
      "gridPos": { "x": 8, "y": 26, "w": 16, "h": 6 },
      "targets": [
        {
          "expr": "grafanagent_eval_judge_score{set=\"golden_set\", mode=\"llm\"}",
          "legendFormat": "{{dimension}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" }
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 5 }
      }
    },
    {
      "id": 33,
      "type": "bargauge",
      "title": "Pass rate by skill",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "grafanagent_eval_per_skill_pass_rate{set=\"golden_set\", mode=\"llm\"}",
          "legendFormat": "{{skill}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" }
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 1, "unit": "percentunit" }
      }
    }
  ]
}
